# Prod workspace (ablackcloudapp-infra-prod)
# Copy values into HCP Terraform workspace variables (Terraform category).
# For local runs: cp prod.tfvars.example prod.tfvars && terraform plan -var-file=prod.tfvars

aws_region       = "us-east-1"
project_name     = "ablackcloudapp"
environment      = "prod"
site_bucket_name = "ablackcloudapp.com"

# ACM cert for ablackcloudapp.com — must be in us-east-1 for CloudFront.
# AWS Console → Certificate Manager → US East (N. Virginia) → copy ARN
acm_certificate_arn = "arn:aws:acm:us-east-1:398080922284:certificate/YOUR-CERT-ID"

# Optional (defaults in variables.tf)
# price_class       = "PriceClass_100"
# enable_versioning = true
